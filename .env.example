# Database
DATABASE_URL=postgresql://user:password@localhost:5432/easymarket

# JWT — minimo 32 caratteri, genera con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=your-jwt-secret-minimum-32-chars-here
REFRESH_TOKEN_SECRET=your-refresh-secret-here
# Durata access token (default: 15m — non aumentare oltre 1h)
# JWT_EXPIRES_IN=15m

# Admin — protegge endpoint /api/finetuning/export|trigger e /api/user/getAllUsers
# Genera con: node -e "require('crypto').randomBytes(32).toString('hex')"
ADMIN_API_KEY=your-secret-admin-key-here

# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=easymarket-uploads

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# AI Services — V1
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
# Chiave segreta — test: sk_test_... | produzione: sk_live_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# URL Payment Link — Stripe Dashboard → Payment Links → copia il link
# Es: https://buy.stripe.com/test/xxxxxxxxxxxx
STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test/xxxxxxxxxxxx

# App
PORT=3000
NODE_ENV=development

# CORS — origini consentite in produzione (virgola-separated)
# Es: ALLOWED_ORIGINS=https://app.easymarket.it,https://b2b.easymarket.it
# In sviluppo lascia vuoto (accetta tutto)
# ALLOWED_ORIGINS=

# Vector DB (V2)
QDRANT_URL="http://localhost:6333"  # start with: docker compose up -d

# Redis (V2) — opzionale, fallback in-memory se non impostato
# REDIS_URL=redis://localhost:6379

# ML Service (V3) — FastAPI + Prophet
# start with: docker compose up -d  (o python uvicorn main:app --port 8000)
ML_SERVICE_URL=http://localhost:8000

# V5 — Fine-tuning OCR
# Dopo che il fine-tuning è completato, incolla qui il nome del modello
# es: ft:gpt-4o-mini-2024-07-18:easymarket-receipt-ocr:xxxxxxxx
# FINETUNED_OCR_MODEL=

# V5 — Multi-region
# Imposta per attivare read replica PostgreSQL
# READ_DATABASE_URL=postgresql://user:pass@replica-host:5432/easymarket
REGION=eu-west
